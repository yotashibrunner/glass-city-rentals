# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Public base URL of the site (used for absolute links, Stripe redirects).
BASE_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically in production.
# For local dev, point at your local Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/glasscity
# Set to "true" for Railway managed Postgres (requires SSL). Leave unset locally.
DB_SSL=false

# ── Auth (Phase 2) ───────────────────────────────────────────────────
# JWT_SECRET=change-me-to-a-long-random-string

# ── Stripe (Phase 5) ─────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Email — Resend (Phase 5) ─────────────────────────────────────────
# RESEND_API_KEY=
# FROM_EMAIL=bookings@glasscitytrailerrentals.com

# ── SMS — Twilio (Phase 8) ───────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ── Web Push — VAPID (Phase 8) ───────────────────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:owner@glasscitytrailerrentals.com

# ── Monitoring — Sentry (Phase 9) ────────────────────────────────────
# SENTRY_DSN=
