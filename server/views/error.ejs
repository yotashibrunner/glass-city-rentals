<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= code %> — <%= title %> | Glass City Trailer Rentals</title>
  <link rel="icon" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-head">
    <div class="site-head-inner">
      <a class="back" href="/">‹ <span>Home</span></a>
      <a href="/"><img class="logo" src="/images/logo.png" alt="Glass City Trailer Rentals" /></a>
      <a class="call" href="tel:+14196543584" aria-label="Call Glass City Trailer Rentals">Call</a>
    </div>
  </header>

  <main class="container" id="main">
    <div style="max-width:560px;margin:64px auto 96px;text-align:center;">
      <div class="eyebrow" style="justify-content:center;">Error <%= code %></div>
      <h1 class="display" style="font-size:clamp(48px,12vw,96px);margin:8px 0;"><%= code %></h1>
      <p class="display" style="font-size:clamp(22px,5vw,34px);margin:0 0 14px;"><%= title %></p>
      <p class="dim" style="margin:0 auto 28px;max-width:420px;"><%= message %></p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a class="btn btn-primary" href="/" style="width:auto;">Back to Home</a>
        <a class="btn btn-ghost" href="tel:+14196543584" style="width:auto;">Call (419) 654-3584</a>
      </div>
    </div>
  </main>
</body>
</html>
